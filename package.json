{
  "name": "pie",
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "extensions/pie-kumar303-config"
    ]
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",

    "typecheck": "tsc"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/eslint-plugin": "^1.6.15",
    "eslint": "^10.2.0",
    "prettier": "^3",
    "typescript": "^5",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "^0.63.1",
    "@mariozechner/pi-coding-agent": "^0.63.1",
    "@mariozechner/pi-tui": "^0.63.1",
    "@sinclair/typebox": "*"
  }
}
